# VizAI Backend Configuration Template

# FastAPI settings
PROJECT_NAME="VizAI API"
SECRET_KEY="super_secret_jwt_key_for_vizai_development_12345!"

# Database Configuration
# Default is SQLite in the backend directory.
# For PostgreSQL: postgresql://username:password@localhost:5432/vizai
DATABASE_URL="sqlite:///./vizai.db"

# Upload Folder path
UPLOAD_DIR="./uploads"

# Optional: Google Gemini API Key for advanced AI insights (leave empty for local statistical analytics engine)
GEMINI_API_KEY=""
